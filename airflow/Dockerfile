# Custom Airflow image: adds the People Analytics extractor + dbt-duckdb so
# Airflow workers can run the pipeline in-process. The base image is the
# official slim Airflow build pinned to a stable 2.x release.
FROM apache/airflow:2.10.4-python3.12

USER root

# git is needed by some dbt packages; build-essential keeps wheels happy on slim.
RUN apt-get update && apt-get install -y --no-install-recommends \
        git build-essential \
    && rm -rf /var/lib/apt/lists/*

USER airflow

# Project Python deps. Pinned-light here to avoid drift with pyproject.toml; the
# real source of truth in production would be a constraints file generated by
# `uv pip compile`.
COPY airflow/requirements.txt /requirements.txt
RUN pip install --no-cache-dir -r /requirements.txt

# Make the in-tree extractor package importable inside the worker.
ENV PYTHONPATH=/opt/airflow
